# CFG-01 — Exemplo de variáveis de ambiente do BikeToGo
# NUNCA coloque valores reais aqui. Copie para .env (ignorado pelo Git) e preencha localmente.

# Aplicação
APP_ENV=development
APP_PORT=3000

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biketogo
DB_USER=changeme
DB_PASSWORD=changeme

# Autenticação / segurança
JWT_SECRET=changeme

# Integrações externas (preencher conforme necessário)
# PAYMENT_API_KEY=
